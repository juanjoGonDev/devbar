# ──────────────────────────────────────────────────────────────────────
# pnpm security & reproducibility config
#
# NOTE: we deliberately do NOT set `ignore-scripts=true`. In pnpm 10 the
# build scripts (preinstall/install/postinstall) of *dependencies* are
# already blocked by default and only run for packages explicitly listed
# in `package.json > pnpm.onlyBuiltDependencies`. Setting `ignore-scripts`
# would ALSO block those allow-listed builds (e.g. electron downloading
# its binary), which we need. The allow-list is the correct lever here.
# ──────────────────────────────────────────────────────────────────────

# ── Version pinning ───────────────────────────────────────────────────
# Installs write exact versions to package.json (no ^ / ~ drift).
save-exact=true
save-prefix=

# ── Supply-chain cooldown ─────────────────────────────────────────────
# Refuse to install a version published less than 3 days (4320 min) ago.
# Most compromised-package incidents are caught and yanked within hours
# to a couple of days, so this window dodges freshly-poisoned releases.
# Raise it for more caution, lower it if you need a same-day patch.
minimum-release-age=4320

# ── Lockfile reproducibility / store integrity ────────────────────────
# Use the committed lockfile as-is when it's in sync; only re-resolve when
# package.json genuinely changed. CI additionally passes --frozen-lockfile.
prefer-frozen-lockfile=true
# Re-hash every file pulled from the content-addressable store before
# linking, so a tampered store can't silently inject code.
verify-store-integrity=true
# Warn (don't silently run) if installed deps drift from the lockfile
# before executing a `pnpm run` script.
verify-deps-before-run=warn

# ── Engine + dependency strictness ────────────────────────────────────
# Enforce the node/pnpm versions declared in package.json > engines.
engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false

# ── Audit ─────────────────────────────────────────────────────────────
# `pnpm audit` fails on moderate+ advisories.
audit-level=moderate

# ── node_modules layout ───────────────────────────────────────────────
# electron-packager walks a flat (npm-style) node_modules to bundle the
# app's runtime deps; pnpm's default isolated/symlinked store hides
# transitive deps (e.g. electron-store -> conf) from that walk and the
# pack fails with "Failed to locate module". `hoisted` gives a flat tree
# so packaging works. This only changes the on-disk layout — it does NOT
# weaken the supply-chain protections above (cooldown, blocked build
# scripts, store integrity, exact pinning all still apply).
node-linker=hoisted

{
  "name": "devbar",
  "version": "0.1.0",
  "description": "Menu bar service launcher for Mac (WAMP-style)",
  "main": "src/main.js",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.16.0"
  },
  "scripts": {
    "start": "electron .",
    "fetch-electron": "node node_modules/electron/install.js",
    "pack": "electron-packager . DevBar --platform=darwin --out=dist --overwrite --icon=assets/icon.icns",
    "install-local": "bash scripts/install-local.sh",
    "logs": "tail -F \"$HOME/Library/Logs/DevBar/app.log\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deadcode": "knip",
    "deps:check": "depcruise src renderer scripts --config .dependency-cruiser.cjs",
    "quality": "pnpm lint:strict && pnpm deadcode && pnpm deps:check && pnpm test",
    "postinstall": "node scripts/install-hooks.js"
  },
  "devDependencies": {
    "dependency-cruiser": "16.10.4",
    "electron": "42.2.0",
    "electron-packager": "17.1.2",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "knip": "6.16.1",
    "lefthook": "2.1.9",
    "prettier": "3.8.4",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "electron-store": "11.0.2",
    "menubar": "9.5.2",
    "uuid": "14.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
